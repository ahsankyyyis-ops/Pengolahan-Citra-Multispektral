<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OreSight - Deteksi Mineral</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        body { margin: 0; padding: 0; font-family: Arial, sans-serif; display: flex; height: 100vh; }
        #sidebar { width: 300px; background: #2c3e50; color: white; padding: 20px; box-sizing: border-box; z-index: 1000; }
        #map { flex-grow: 1; height: 100%; }
        select, button { width: 100%; padding: 10px; margin-top: 10px; margin-bottom: 20px; border-radius: 4px; border: none; }
        button { background: #27ae60; color: white; font-weight: bold; cursor: pointer; }
        button:hover { background: #219653; }
    </style>
</head>
<body>

    <div id="sidebar">
        <h2>OreSight Web</h2>
        <hr>
        <p>1. Pilih Data Satelit:</p>
        <select id="satelit">
            <option value="sentinel2">Sentinel-2 (10m)</option>
            <option value="landsat8">Landsat 8/9 (30m)</option>
        </select>

        <p>2. Pilih Target Mineral:</p>
        <select id="mineral">
            <option value="clay">Clay Alteration (Lempung)</option>
            <option value="iron">Iron Oxide (Besi Oksida)</option>
        </select>

        <button onclick="prosesDeteksi()">PROSES CITRA</button>
        <button style="background:#2980b9;">DOWNLOAD (.TIF)</button>
    </div>

    <div id="map"></div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        // Inisialisasi Peta Indonesia (Koordinat tengah Indonesia)
        var map = L.map('map').setView([-2.5, 118], 5);

        // Menambahkan Base Map (Peta Google/OpenStreetMap)
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '© OpenStreetMap'
        }).addTo(map);

        function prosesDeteksi() {
            var sat = document.getElementById('satelit').value;
            var min = document.getElementById('mineral').value;
            alert("Memproses data " + sat + " untuk deteksi " + min + "...\n(Backend Python akan diintegrasikan di tahap berikutnya)");
        }
    </script>
</body>
</html> 
